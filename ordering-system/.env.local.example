# Supabase プロジェクト設定
# Supabaseダッシュボード > Settings > API から取得してください

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# サービスロールキー（APIルートでの直接DB操作に使用）
# Settings > API > service_role から取得（外部に漏らさないこと）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────
# LINE ログイン / LIFF 設定
# ─────────────────────────────────────────

# LIFF ID
# LINE Developers > LIFF タブ > LIFF URL のID部分
# 例: 1234567890-AbCdEfGh
# 未設定の場合は LINE認証をスキップします（ローカル開発用）
NEXT_PUBLIC_LIFF_ID=your-liff-id-here

# LINE公式アカウント 友だち追加URL
# LINE Official Account Manager または LINE Developers で確認
# 例: https://line.me/R/ti/p/@your-line-id
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=https://line.me/R/ti/p/@your-line-official-account-id

# LINE Messaging API チャネルシークレット（Webhook署名検証用）
# LINE Developers > Messaging API > チャネルシークレット
LINE_CHANNEL_SECRET=your-channel-secret-here
